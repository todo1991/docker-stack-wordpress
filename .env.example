# Password for the MariaDB root user
MARIADB_ROOT_PASSWORD=your_root_password
# Name of the initial WordPress database
MARIADB_DATABASE=wordpress
# Database user for WordPress
MARIADB_USER=wpuser
# Password for `MARIADB_USER`
MARIADB_PASSWORD=wp_password
# Domain name used for the site and SSL certificate
DOMAIN=example.com
# Email address used to register Let's Encrypt certificates
EMAIL=you@example.com
# WordPress table prefix. For a NEW site keep the default.
# When importing an EXISTING database, set this to the prefix used in the dump (usually wp_)
WORDPRESS_TABLE_PREFIX=wpstack_
